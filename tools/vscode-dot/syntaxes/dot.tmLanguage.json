{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "DOT",
  "scopeName": "source.dot",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#functions" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.dot",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.dot",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.dot",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.dot",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.dot",
          "match": "\\b(observe|agent|every|at|to|when|then|after|if|and|or|not)\\b"
        },
        {
          "name": "keyword.other.dot",
          "match": "\\b(plain|seconds|minutes|hours|days)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.dot",
          "match": "\\.(gate|pulse|chain|mesh|bloom|fade|forge)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.dot",
          "match": "\\b(measure|state|event|claim|bond)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.dot",
          "match": "(>=|<=|>|<|=|!=)"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.dot",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
